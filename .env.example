# SearxNG instance (locally deployed)
SEARXNG_URL=http://host.docker.internal:8080

# Ollama instance
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma3:4b

# Cache
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=2000

# Page fetching
MAX_CONCURRENT_FETCHES=5
PAGE_FETCH_TIMEOUT_SECONDS=8.0
MAX_SOURCES=5

# Query builder
QUERY_BUILDER_TIMEOUT_SECONDS=6.0

# --- Security ---
# Require this key in the X-API-Key header. Leave empty ONLY for local dev;
# an empty key means every endpoint is unauthenticated.
API_KEY=

# Per-client-IP edge rate limit (0 disables).
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60.0

# Max fetched page body in bytes (memory-exhaustion guard).
MAX_PAGE_BYTES=3000000

# Max concurrent headless Chromium instances.
PLAYWRIGHT_MAX_CONCURRENCY=2

# SearxNG content filter: 0=off, 1=moderate, 2=strict.
SEARXNG_SAFESEARCH=1
