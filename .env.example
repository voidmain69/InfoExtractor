# SearxNG instance (locally deployed)
SEARXNG_URL=http://host.docker.internal:8080

# Ollama instance. Keep the model aligned with catalog-service
# (qwen2.5:14b-instruct) so the shared GPU host holds ONE model in VRAM instead
# of swapping between the two services' models.
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:14b-instruct

# TEI (Text Embeddings Inference) — optional semantic tier for the attribute→
# label match. Empty TEI_DENSE_URL disables it (LLM-only, as before). Point at
# the same bge-m3 / bge-reranker-v2-m3 fleet catalog-service uses.
TEI_DENSE_URL=
TEI_RERANK_URL=
TEI_TIMEOUT_SECONDS=10.0

# Cache
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=2000

# Page fetching
MAX_CONCURRENT_FETCHES=5
PAGE_FETCH_TIMEOUT_SECONDS=8.0
MAX_SOURCES=5

# Query builder
QUERY_BUILDER_TIMEOUT_SECONDS=6.0

# --- Security ---
# Require this key in the X-API-Key header. Leave empty ONLY for local dev;
# an empty key means every endpoint is unauthenticated.
API_KEY=

# Per-client-IP edge rate limit (0 disables).
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60.0

# Max fetched page body in bytes (memory-exhaustion guard).
MAX_PAGE_BYTES=3000000

# Max concurrent headless Chromium instances.
PLAYWRIGHT_MAX_CONCURRENCY=2

# SearxNG content filter: 0=off, 1=moderate, 2=strict.
SEARXNG_SAFESEARCH=1
