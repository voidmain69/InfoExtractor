# SearxNG instance (locally deployed)
SEARXNG_URL=http://host.docker.internal:8080

# Ollama instance
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma3:4b

# Cache
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=2000

# Page fetching
MAX_CONCURRENT_FETCHES=5
PAGE_FETCH_TIMEOUT_SECONDS=8.0
MAX_SOURCES=5

# Query builder
QUERY_BUILDER_TIMEOUT_SECONDS=6.0
